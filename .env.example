# ── FitHub ortam değişkenleri ────────────────────────────────────────────────
# Bu dosyayı .env.local olarak kopyalayıp değerleri doldur. .env.local git'e
# gönderilmez (gizli anahtarlar). Aşağıdaki NEXT_PUBLIC_* değerleri tarayıcıya
# gider — buraya ASLA gizli anahtar koyma.

# Supabase — proje panelinden (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# Supabase'in güncel publishable anahtarı tercih edilir. Eski anon anahtarı
# uygulamada geriye dönük desteklenir, ancak buraya ASLA service_role yazmayın.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Yayına aldığın gerçek alan adı. SEO/canonical, Open Graph, sitemap ve robots
# bu adresten beslenir. Boş bırakılırsa Vercel üretim adresi ya da localhost
# kullanılır. Yayın öncesi MUTLAKA gerçek alan adınla doldur.
NEXT_PUBLIC_SITE_URL=https://senin-alan-adin.com

# Gemini (yapay zekâ koç + diyet planı). SUNUCU tarafı — NEXT_PUBLIC_ DEĞİL.
# Tanımlı değilse asistan yerel motora düşer, diyet planı devre dışı kalır.
SENTEZ_API_KEY=
# Opsiyonel model override (varsayılan: gemini-2.0-flash)
# SENTEZ_MODEL=gemini-2.0-flash
